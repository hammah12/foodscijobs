rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if database is matching
    match /profile/{docId} {
      allow read, write: if true;
    }
    match /jobs/{jobId} {
      allow read, write: if true;
    }
    match /config/{docId} {
      allow read, write: if true;
    }
  }
}
